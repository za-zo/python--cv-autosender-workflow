# ==========================
# DataBase
# ==========================

MONGO_URI=mongodb+srv://...
MONGO_DB_NAME=your_db_name

# ==========================
# Notification
# ==========================

ENABLE_NOTIFICATIONS=false
NOTIFICATION_EMAIL=your-notification@email.com
# Optional: Gmail (or other) credentials to send failure alerts before a pool email is claimed
NOTIFICATION_SMTP_EMAIL=
NOTIFICATION_SMTP_PASSWORD=

# ==========================
# Logs
# ==========================

MASK_LOGS=false